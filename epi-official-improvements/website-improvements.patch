+    renderBatchResults(results);
+    showState('batch');
+}
+
+function renderBatchResults(items) {
+    const list = document.getElementById('batch-results-list');
+    list.innerHTML = '';
+    let countVerified = 0, countUnsigned = 0, countFailed = 0;
+
+    items.forEach(({ file, result }) => {
+        let chipClass, chipLabel, detailRows;
+        if (!result.success) {
+            chipClass = 'bchip-error'; chipLabel = 'Error'; countFailed++;
+            detailRows = [['Error', result.error || 'Unknown error']];
+        } else {
+            const m   = result.manifest;
+            const integ = result.verificationDetails.integrity;
+            const sig   = result.verificationDetails.signature;
+            if (!integ.valid) {
+                chipClass = 'bchip-tampered'; chipLabel = 'Tampered'; countFailed++;
+            } else if (sig.valid) {
+                chipClass = 'bchip-verified'; chipLabel = 'Verified'; countVerified++;
+            } else if (sig.level === 'UNSIGNED') {
+                chipClass = 'bchip-unsigned'; chipLabel = 'Unsigned'; countUnsigned++;
+            } else {
+                chipClass = 'bchip-error'; chipLabel = 'Sig Error'; countFailed++;
+            }
+            detailRows = [
+                ['Workflow ID', m.workflow_id || '—'],
+                ['Created',     m.created_at ? new Date(m.created_at).toLocaleString() : '—'],
+                ['Signer',      m.signature ? m.signature.split(':')[1] : 'None'],
+                ['Files',       Object.keys(m.file_manifest || {}).length + ' file(s) checked'],
+                ['Integrity',   integ.valid ? 'PASS ✓' : `FAIL — ${integ.mismatches.length} mismatch(es)`],
+                ['Signature',   sig.valid ? `Valid (${sig.algorithm})` : (sig.level || sig.error || 'Invalid')],
+            ];
+        }
+        const fileSizeKb = (file.size / 1024).toFixed(1) + ' KB';
+        const detailHtml = detailRows.map(([k, v]) =>
+            `<div class="batch-detail-key">${k}</div><div class="batch-detail-value">${v}</div>`
+        ).join('');
+
+        const item = document.createElement('div');
+        item.className = 'batch-result-item';
+        item.setAttribute('role', 'listitem');
+        item.innerHTML = `
+            <div class="batch-result-header" tabindex="0" role="button"
+                 aria-expanded="false" aria-label="Toggle details for ${file.name}">
+                <span class="batch-status-chip ${chipClass}">${chipLabel}</span>
+                <span class="batch-result-filename" title="${file.name}">${file.name}</span>
+                <span class="batch-result-filesize">${fileSizeKb}</span>
+                <span class="batch-result-expand" aria-hidden="true">▾</span>
+            </div>
+            <div class="batch-result-detail">
+                <div class="batch-detail-grid">${detailHtml}</div>
+            </div>
+        `;
+        const header = item.querySelector('.batch-result-header');
+        const toggle = () => {
+            const isOpen = item.classList.toggle('open');
+            header.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
+        };
+        header.addEventListener('click', toggle);
+        header.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); } });
+        list.appendChild(item);
+    });
+
+    const parts = [];
+    if (countVerified) parts.push(`${countVerified} verified`);
+    if (countUnsigned) parts.push(`${countUnsigned} unsigned`);
+    if (countFailed)   parts.push(`${countFailed} failed`);
+    document.getElementById('batch-summary-line').textContent =
+        `${items.length} file${items.length !== 1 ? 's' : ''} · ${parts.join(' · ')}`;
+}
