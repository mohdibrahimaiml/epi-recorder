 // Note: .terminal-interactive elements are initialized by TerminalDemo in terminal-demo.js
 
+// ── Homepage Quick-Verify Drop Zone ──────────────────────────────────────────
+(function initHeroDropZone() {
+    const dz = document.getElementById('hero-drop-zone');
+    if (!dz) return; // Only runs on index.html
+
+    const fileInput   = document.getElementById('hero-file-input');
+    const idleOverlay = document.getElementById('hero-dz-idle');
+    const overOverlay = document.getElementById('hero-dz-over');
+    const statusEl    = document.getElementById('hero-dz-status');
+
+    function setDragState(active) {
+        if (active) {
+            dz.classList.add('dz-dragover');
+            idleOverlay.style.display = 'none';
+            overOverlay.style.display = '';
+        } else {
+            dz.classList.remove('dz-dragover');
+            idleOverlay.style.display = '';
+            overOverlay.style.display = 'none';
+        }
+    }
+
+    dz.addEventListener('click', () => fileInput.click());
+    dz.addEventListener('keydown', (e) => {
+        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
+    });
+    dz.addEventListener('dragover',  (e) => { e.preventDefault(); setDragState(true); });
+    dz.addEventListener('dragleave', (e) => { if (!dz.contains(e.relatedTarget)) setDragState(false); });
+    dz.addEventListener('drop', (e) => {
+        e.preventDefault();
+        setDragState(false);
+        const file = e.dataTransfer.files[0];
+        if (file) processHeroFile(file);
+    });
+    fileInput.addEventListener('change', (e) => {
+        if (e.target.files[0]) processHeroFile(e.target.files[0]);
+    });
+
+    function processHeroFile(file) {
+        if (!file.name.endsWith('.epi')) {
+            statusEl.style.color = 'var(--color-error)';
+            statusEl.textContent = 'Please drop a .epi file.';
+            setTimeout(() => { statusEl.textContent = ''; }, 3000);
+            return;
+        }
+        // Guard: large files won't fit in sessionStorage (~5–10 MB limit)
+        if (file.size > 8 * 1024 * 1024) {
+            statusEl.style.color = 'var(--color-warning)';
+            statusEl.textContent = 'File is large — opening verifier directly.';
+            setTimeout(() => { window.location.href = 'verify.html'; }, 800);
+            return;
+        }
+        statusEl.style.color = 'var(--color-primary-light)';
+        statusEl.textContent = 'Reading ' + file.name + '…';
+        const reader = new FileReader();
+        reader.onload = function (ev) {
+            try {
+                const bytes = new Uint8Array(ev.target.result);
+                let binary = '';
+                bytes.forEach(b => { binary += String.fromCharCode(b); });
+                sessionStorage.setItem('epi_handoff', JSON.stringify({
+                    name: file.name,
+                    size: file.size,
+                    lastModified: file.lastModified,
+                    data: btoa(binary)
+                }));
+                statusEl.textContent = 'Redirecting to verifier…';
+                window.location.href = 'verify.html';
+            } catch (err) {
+                statusEl.style.color = 'var(--color-error)';
+                statusEl.textContent = 'Error: ' + err.message;
+            }
+        };
+        reader.onerror = () => {
+            statusEl.style.color = 'var(--color-error)';
+            statusEl.textContent = 'Could not read the file.';
+        };
+        reader.readAsArrayBuffer(file);
+    }
+})();
+
