# ── Core capture settings ───────────────────────────────────────────────────
EPI_GATEWAY_BATCH_SIZE=50
EPI_GATEWAY_BATCH_TIMEOUT=2.0
EPI_GATEWAY_RETENTION_MODE=redacted_hashes
EPI_GATEWAY_PROXY_FAILURE_MODE=fail-open
EPI_GATEWAY_CAPTURE_SCOPE=consequential

# ── Network / CORS ──────────────────────────────────────────────────────────
EPI_GATEWAY_ALLOWED_ORIGINS=*

# ── Authentication ──────────────────────────────────────────────────────────
# Use ONE of the two auth methods below (or neither for no auth).
EPI_GATEWAY_ACCESS_TOKEN=
EPI_GATEWAY_USERS_FILE=./config/gateway-users.example.json
EPI_GATEWAY_SESSION_TTL_HOURS=12

# ── Signing ─────────────────────────────────────────────────────────────────
EPI_GATEWAY_DISABLE_SIGNING=false
EPI_GATEWAY_KEYS_DIR=
EPI_GATEWAY_SIGNING_KEY_NAME=default

# ── Reliability ─────────────────────────────────────────────────────────────
# Max capture requests per minute per client IP (0 = disabled)
EPI_GATEWAY_CAPTURE_RATE_LIMIT=1000
# Max request body size in bytes (default 10 MB)
EPI_GATEWAY_MAX_REQUEST_BODY_BYTES=10485760

# ── Notifications ───────────────────────────────────────────────────────────
# POST to this URL when a case reaches "needs_review" status
# Supports Slack incoming webhooks, Teams, PagerDuty, etc.
EPI_GATEWAY_WEBHOOK_URL=
