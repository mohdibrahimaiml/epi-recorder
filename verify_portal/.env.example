# EPI Portal — Environment Configuration
# Copy to .env and fill in values

# Paddle Billing (live)
PADDLE_ENV=live
PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_CLIENT_TOKEN=live_xxxxxxxxxxxxxxxxx
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret_here

# Paddle Price IDs — create these in Paddle dashboard under Catalog > Products
# Format: pri_01xxxxxxxxxxxxxxxx
PADDLE_PRICE_STARTER_MONTH=pri_xxxxxxxxxxxxxxxx
PADDLE_PRICE_STARTER_YEAR=pri_xxxxxxxxxxxxxxxx
PADDLE_PRICE_PRO_MONTH=pri_xxxxxxxxxxxxxxxx
PADDLE_PRICE_PRO_YEAR=pri_xxxxxxxxxxxxxxxx
PADDLE_PRICE_ADVANCED_MONTH=pri_xxxxxxxxxxxxxxxx
PADDLE_PRICE_ADVANCED_YEAR=pri_xxxxxxxxxxxxxxxx

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=
