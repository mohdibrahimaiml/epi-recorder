# ── Core capture settings ───────────────────────────────────────────────────
EPI_GATEWAY_BATCH_SIZE=50
EPI_GATEWAY_BATCH_TIMEOUT=2.0
EPI_GATEWAY_RETENTION_MODE=redacted_hashes
EPI_GATEWAY_PROXY_FAILURE_MODE=fail-open
EPI_GATEWAY_CAPTURE_SCOPE=consequential

# ── Network / CORS ──────────────────────────────────────────────────────────
EPI_GATEWAY_ALLOWED_ORIGINS=*

# ── Authentication ──────────────────────────────────────────────────────────
# Use ONE of the two auth methods below (or neither for no auth).
EPI_GATEWAY_ACCESS_TOKEN=
EPI_GATEWAY_USERS_FILE=./config/gateway-users.example.json
EPI_GATEWAY_SESSION_TTL_HOURS=12

# ── Signing ─────────────────────────────────────────────────────────────────
EPI_GATEWAY_DISABLE_SIGNING=false
EPI_GATEWAY_KEYS_DIR=
EPI_GATEWAY_SIGNING_KEY_NAME=default

# ── Reliability ─────────────────────────────────────────────────────────────
# Max capture requests per minute per client IP (0 = disabled)
EPI_GATEWAY_CAPTURE_RATE_LIMIT=1000
# Max request body size in bytes (default 10 MB)
EPI_GATEWAY_MAX_REQUEST_BODY_BYTES=10485760

# ── Notifications ───────────────────────────────────────────────────────────
# POST to this URL when a case reaches "needs_review" status
# Supports Slack incoming webhooks, Teams, PagerDuty, etc.
EPI_GATEWAY_WEBHOOK_URL=

# Hosted share links
EPI_GATEWAY_SHARE_ENABLED=false
EPI_GATEWAY_SHARE_SITE_BASE_URL=https://epilabs.org
EPI_GATEWAY_SHARE_API_BASE_URL=https://api.epilabs.org
EPI_GATEWAY_SHARE_MAX_UPLOAD_BYTES=5242880
EPI_GATEWAY_SHARE_DEFAULT_EXPIRY_DAYS=30
EPI_GATEWAY_SHARE_MAX_EXPIRY_DAYS=30
EPI_GATEWAY_SHARE_RATE_LIMIT_PER_HOUR=10
EPI_GATEWAY_SHARE_QUOTA_BYTES_PER_30D=104857600
EPI_GATEWAY_SHARE_IP_HMAC_SECRET=
EPI_GATEWAY_SHARE_S3_ENDPOINT=
EPI_GATEWAY_SHARE_S3_REGION=auto
EPI_GATEWAY_SHARE_S3_BUCKET=
EPI_GATEWAY_SHARE_S3_ACCESS_KEY_ID=
EPI_GATEWAY_SHARE_S3_SECRET_ACCESS_KEY=

# Approval delivery for pilot reviewers
EPI_APPROVAL_BASE_URL=http://127.0.0.1:8765
EPI_APPROVAL_WEBHOOK_URL=
EPI_APPROVAL_WEBHOOK_SECRET=
EPI_APPROVAL_WEBHOOK_TIMEOUT_SECONDS=10

# Optional SMTP fallback
EPI_SMTP_HOST=
EPI_SMTP_PORT=587
EPI_SMTP_USER=
EPI_SMTP_PASSWORD=
EPI_SMTP_FROM=
